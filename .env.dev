# ============================================================
# DEV Environment Configuration
# ============================================================
ENV_NAME=dev
APP_VERSION=latest
DOCKER_REGISTRY=ghcr.io/tjstar09/diffusion-simulator
DOCKER_TAG=dev

# Simulation parameters (can be overridden per environment)
DIFFUSION_STEPS=5
BETA_START=0.02
BETA_END=0.5
NUM_RUNS=10

# Plotting
SAVE_PLOTS=true
PLOT_DPI=150